# Portfolio Assistant Configuration
# Copy this to .env.local (which is in .gitignore) and fill in your values
# DO NOT commit .env.local to git

# OpenRouter API Key (get from https://openrouter.ai)
# Only needed if NOT using Cloudflare Worker
OPENROUTER_API_KEY=sk-or-xxxxx-your-actual-key-here

# Cloudflare Worker URL (if using Cloudflare Worker proxy)
# Format: https://your-worker-name.your-subdomain.workers.dev
CLOUDFLARE_WORKER_URL=https://tyler-portfolio.your-subdomain.workers.dev

# Optional: For local testing/development
DEV_MODE=false
